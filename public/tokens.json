{
  "$schema": "https://schemas.tokens.studio/latest/tokens.schema.json",
  "global": {
    "color": {
      "dark-blue": {
        "$value": "#0e375d",
        "$type": "color",
        "$description": "Color primario de marca. Fondo Pintura Interior, texto sobre fondos claros."
      },
      "brown": {
        "$value": "#834f31",
        "$type": "color",
        "$description": "Pintura Arquitectónica Exterior."
      },
      "red": {
        "$value": "#ee3e23",
        "$type": "color",
        "$description": "Color de acción / CTA. Botones primarios, acento."
      },
      "crimson": {
        "$value": "#b33634",
        "$type": "color",
        "$description": "Impermeabilizante 100% acrílico."
      },
      "gold": {
        "$value": "#edb038",
        "$type": "color",
        "$description": "Pintura de Tráfico. Texto oscuro sobre este fondo."
      },
      "gray": {
        "$value": "#b9b9b9",
        "$type": "color",
        "$description": "Primer Epóxico Rico en Zinc. Fondos neutros. Texto oscuro sobre este fondo."
      },
      "cream": {
        "$value": "#f9f6f4",
        "$type": "color",
        "$description": "Fondos claros, tarjetas, CTA de imagen."
      },
      "light": {
        "$value": "#fffcfb",
        "$type": "color",
        "$description": "Texto sobre fondos oscuros (equivalente a blanco cálido)."
      },
      "white": {
        "$value": "#ffffff",
        "$type": "color",
        "$description": "Fondo base del sitio."
      }
    },
    "typography": {
      "fontFamily": {
        "clash": {
          "$value": "Clash Display",
          "$type": "fontFamily",
          "$description": "Fuente principal para headings y títulos."
        },
        "montserrat": {
          "$value": "Montserrat",
          "$type": "fontFamily",
          "$description": "Fuente de cuerpo, UI text, botones de texto."
        },
        "roboto": {
          "$value": "Roboto",
          "$type": "fontFamily",
          "$description": "Fuente para botones CTA y captions."
        }
      },
      "fontSize": {
        "12": { "$value": "12px", "$type": "fontSize", "$description": "Caption / Legales" },
        "16": { "$value": "16px", "$type": "fontSize", "$description": "Text Regular — botones texto, tags" },
        "18": { "$value": "18px", "$type": "fontSize", "$description": "Body 2 — texto de sección" },
        "20": { "$value": "20px", "$type": "fontSize", "$description": "Body 1 / Sub-Heading / Button CTA" },
        "28": { "$value": "28px", "$type": "fontSize", "$description": "Heading tendencias" },
        "32": { "$value": "32px", "$type": "fontSize", "$description": "Heading 3 / Cards / Usos title" },
        "48": { "$value": "48px", "$type": "fontSize", "$description": "Heading 2 — títulos de sección" },
        "60": { "$value": "60px", "$type": "fontSize", "$description": "Heading 1 — Hero" }
      },
      "fontWeight": {
        "regular": { "$value": "400", "$type": "fontWeight" },
        "medium":  { "$value": "500", "$type": "fontWeight" },
        "semibold":{ "$value": "600", "$type": "fontWeight" },
        "bold":    { "$value": "700", "$type": "fontWeight" }
      },
      "lineHeight": {
        "tight":  { "$value": "1.2", "$type": "lineHeight", "$description": "Headings" },
        "normal": { "$value": "1.4", "$type": "lineHeight", "$description": "Buttons" },
        "relaxed":{ "$value": "1.5", "$type": "lineHeight", "$description": "Body text" },
        "loose":  { "$value": "1.6", "$type": "lineHeight", "$description": "Long-form body" }
      },
      "letterSpacing": {
        "wide": { "$value": "0.64px", "$type": "letterSpacing", "$description": "Usos heading tracking" }
      }
    },
    "spacing": {
      "1":  { "$value": "4px",  "$type": "spacing", "$description": "py-1 — Tag pill vertical padding" },
      "2":  { "$value": "8px",  "$type": "spacing", "$description": "gap-2 — Icono + texto" },
      "3":  { "$value": "12px", "$type": "spacing", "$description": "Separación pequeña" },
      "4":  { "$value": "16px", "$type": "spacing", "$description": "px-4 / gap-4 — Tags, botones" },
      "5":  { "$value": "20px", "$type": "spacing", "$description": "p-5 — CTA imagen hero" },
      "6":  { "$value": "24px", "$type": "spacing", "$description": "p-6 — Cards, footer newsletter" },
      "8":  { "$value": "32px", "$type": "spacing", "$description": "py-8 — Row colapsado" },
      "10": { "$value": "40px", "$type": "spacing", "$description": "gap-10 — Grids de sección" },
      "12": { "$value": "48px", "$type": "spacing", "$description": "py-12 — Row expandido" },
      "14": { "$value": "56px", "$type": "spacing", "$description": "Espaciado mayor" },
      "16": { "$value": "64px", "$type": "spacing", "$description": "py-16 — Secciones" },
      "20": { "$value": "80px", "$type": "spacing", "$description": "px-20 / gap-20 — Layout principal" }
    },
    "borderRadius": {
      "pill":   { "$value": "32px", "$type": "borderRadius", "$description": "Tag pills de usos" },
      "button": { "$value": "8px",  "$type": "borderRadius", "$description": "Botones CTA" },
      "card":   { "$value": "8px",  "$type": "borderRadius", "$description": "Cards y contenedores" },
      "image":  { "$value": "24px", "$type": "borderRadius", "$description": "Imagen de contacto (rounded-3xl)" }
    },
    "shadow": {
      "cta": {
        "$value": "13px 27px 53px 0px rgba(35,35,35,0.69)",
        "$type": "boxShadow",
        "$description": "Sombra del botón Ver productos en tendencias"
      },
      "hero-cta": {
        "$value": "0 25px 50px -12px rgba(0,0,0,0.5)",
        "$type": "boxShadow",
        "$description": "Sombra del CTA de imagen en hero (shadow-2xl)"
      }
    },
    "motion": {
      "duration": {
        "fast":   { "$value": "200ms", "$type": "other", "$description": "Fade button toggle" },
        "base":   { "$value": "300ms", "$type": "other", "$description": "Fade contenido expandido" },
        "expand": { "$value": "550ms", "$type": "other", "$description": "Expand product row height" }
      },
      "easing": {
        "standard": {
          "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
          "$type": "other",
          "$description": "Easing principal para expansión de rows (Material standard)"
        },
        "ease-out": {
          "$value": "cubic-bezier(0, 0, 0.2, 1)",
          "$type": "other",
          "$description": "Fade de contenido al aparecer"
        }
      },
      "delay": {
        "content": { "$value": "150ms", "$type": "other", "$description": "Delay del fade de contenido tras inicio de expand" }
      }
    }
  },
  "components": {
    "button-primary": {
      "background":    { "$value": "{global.color.red}",        "$type": "color" },
      "text":          { "$value": "#ffffff",                    "$type": "color" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.roboto}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.20}",       "$type": "fontSize" },
      "fontWeight":    { "$value": "{global.typography.fontWeight.medium}",  "$type": "fontWeight" },
      "lineHeight":    { "$value": "{global.typography.lineHeight.normal}",  "$type": "lineHeight" },
      "paddingX":      { "$value": "{global.spacing.4}",        "$type": "spacing" },
      "paddingY":      { "$value": "8px",                        "$type": "spacing" },
      "borderRadius":  { "$value": "{global.borderRadius.button}", "$type": "borderRadius" }
    },
    "button-ghost-light": {
      "background":    { "$value": "transparent",                "$type": "color" },
      "text":          { "$value": "#ffffff",                    "$type": "color" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.roboto}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.20}",       "$type": "fontSize" },
      "fontWeight":    { "$value": "{global.typography.fontWeight.medium}",  "$type": "fontWeight" },
      "height":        { "$value": "42px",                       "$type": "sizing" },
      "paddingX":      { "$value": "{global.spacing.4}",        "$type": "spacing" },
      "borderRadius":  { "$value": "{global.borderRadius.button}", "$type": "borderRadius" }
    },
    "button-ghost-dark": {
      "background":    { "$value": "transparent",                "$type": "color" },
      "text":          { "$value": "{global.color.dark-blue}",   "$type": "color" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.roboto}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.20}",       "$type": "fontSize" },
      "fontWeight":    { "$value": "{global.typography.fontWeight.medium}",  "$type": "fontWeight" },
      "height":        { "$value": "42px",                       "$type": "sizing" },
      "paddingX":      { "$value": "{global.spacing.4}",        "$type": "spacing" },
      "borderRadius":  { "$value": "{global.borderRadius.button}", "$type": "borderRadius" }
    },
    "tag-pill-light": {
      "border":        { "$value": "#ffffff",                    "$type": "color" },
      "text":          { "$value": "#ffffff",                    "$type": "color" },
      "background":    { "$value": "transparent",                "$type": "color" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.montserrat}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.16}",           "$type": "fontSize" },
      "fontWeight":    { "$value": "{global.typography.fontWeight.regular}",    "$type": "fontWeight" },
      "paddingX":      { "$value": "{global.spacing.4}",        "$type": "spacing" },
      "paddingY":      { "$value": "{global.spacing.1}",        "$type": "spacing" },
      "borderRadius":  { "$value": "{global.borderRadius.pill}", "$type": "borderRadius" }
    },
    "tag-pill-dark": {
      "border":        { "$value": "{global.color.dark-blue}",   "$type": "color" },
      "text":          { "$value": "{global.color.dark-blue}",   "$type": "color" },
      "background":    { "$value": "transparent",                "$type": "color" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.montserrat}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.16}",           "$type": "fontSize" },
      "fontWeight":    { "$value": "{global.typography.fontWeight.regular}",    "$type": "fontWeight" },
      "paddingX":      { "$value": "{global.spacing.4}",        "$type": "spacing" },
      "paddingY":      { "$value": "{global.spacing.1}",        "$type": "spacing" },
      "borderRadius":  { "$value": "{global.borderRadius.pill}", "$type": "borderRadius" }
    },
    "input": {
      "border":        { "$value": "#000000",                    "$type": "color" },
      "borderRadius":  { "$value": "{global.borderRadius.card}", "$type": "borderRadius" },
      "padding":       { "$value": "12px",                       "$type": "spacing" },
      "fontFamily":    { "$value": "{global.typography.fontFamily.montserrat}", "$type": "fontFamily" },
      "fontSize":      { "$value": "{global.typography.fontSize.16}",           "$type": "fontSize" }
    },
    "product-row": {
      "paddingX":         { "$value": "{global.spacing.20}",       "$type": "spacing", "$description": "px-20 (80px)" },
      "paddingY-closed":  { "$value": "{global.spacing.8}",        "$type": "spacing", "$description": "py-8 estado colapsado" },
      "paddingY-open":    { "$value": "{global.spacing.12}",       "$type": "spacing", "$description": "py-12 estado expandido" },
      "gap":              { "$value": "{global.spacing.20}",       "$type": "spacing", "$description": "gap-20 entre columnas" },
      "content-gap":      { "$value": "{global.spacing.4}",       "$type": "spacing", "$description": "gap-4 entre elementos internos" },
      "image-min-height": { "$value": "146px",                    "$type": "sizing",  "$description": "Altura mínima imagen colapsada" }
    }
  }
}
